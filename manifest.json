{
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "toast.js", "copyurlwithtitle.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_start"
   } ],
   "description": "Copy hyperlink as Edge does, just press Ctrl-C/Cmd-C in the web page. Shortcut is configurable.",
   "icons": {
      "128": "128.png"
   },
   "manifest_version": 3,
   "name": "Copy hyperlink as Edge does",
   "short_name": "Copy hyperlink as Edge does",
   "permissions": [ "storage" ],
   "options_ui": {
      "page": "options.html",
      "open_in_tab": false
   },
   "version": "0.2"
}
